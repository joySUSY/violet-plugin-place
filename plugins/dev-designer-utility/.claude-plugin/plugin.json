{
  "name": "dev-designer-utility",
  "version": "1.0.0",
  "description": "Design systems architecture, typography engineering, color theory, theme generation, UX strategy, font engineering, and visual artifact production. The mathematical source of truth for every design decision.",
  "author": "Joysusy & Violet Klaudia",
  "license": "PROPRIETARY",
  "engine_type": "skill",
  "keywords": [
    "design-systems",
    "typography",
    "color-theory",
    "ux-strategy",
    "font-engineering",
    "visual-design",
    "design-tokens"
  ],
  "entry": "../SKILL.md",
  "hooks": "../hooks/hooks.json",
  "commands": {
    "prime/design-foundations": "../commands/prime/design-foundations.md"
  },
  "agents": {
    "aria": "../agents/aria.md"
  },
  "cross_engine_boundaries": {
    "ui-implementation": "frontend-dev",
    "brand-strategy": "modules/",
    "font-rust-internals": "rust-coding-engine",
    "image-processing": "developer-tool"
  },
  "file_patterns": [
    "*.tokens.json",
    "*.design-tokens.*",
    "design-system/**",
    "tokens/**",
    "*.otf",
    "*.ttf",
    "*.woff",
    "*.woff2",
    "*.svg",
    "palette.*",
    "theme.*"
  ],
  "portability": {
    "root_var": "${CLAUDE_PLUGIN_ROOT}",
    "paths_relative_to": "plugin.json"
  }
}
